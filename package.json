{
  "name": "lcms",
  "version": "1.0.0",
  "description": "Local CMS with static site export",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"npm run dev --workspace=client\"",
    "server": "node server/index.js",
    "generate": "node generator/index.js",
    "install:all": "npm install && npm install --workspace=client",
    "test": "node --test --test-reporter=spec tests/api.test.js"
  },
  "workspaces": [
    "client"
  ],
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "marked": "^9.1.6",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
